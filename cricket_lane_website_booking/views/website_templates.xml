<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="cricket_lane_booking_page" name="Cricket Lane Booking Page">
        <t t-call="website.layout">
            <div id="wrap" class="o_cricket_booking_page">
                <section class="o_cricket_booking_shell">
                    <div class="o_cricket_booking_widget" data-widget="cricket-booking">
                        <div class="o_cricket_loading">Loading booking options...</div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <record id="menu_book_cricket_lane" model="website.menu">
        <field name="name">Book Cricket Lane</field>
        <field name="url">/book-cricket-lane</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" type="int">50</field>
    </record>
</odoo>
