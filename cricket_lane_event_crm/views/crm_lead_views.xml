<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_cricket_event_inquiries" model="ir.actions.act_window">
        <field name="name">Event Inquiries</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">list,kanban,form,calendar,activity</field>
        <field name="domain">[('cricket_booking_type_id.code', '=', 'event')]</field>
        <field name="context" eval="{'default_type': 'opportunity', 'default_cricket_booking_type_id': ref('cricket_lane_booking.booking_type_event')}"/>
    </record>

    <menuitem id="menu_cricket_event_inquiries"
              name="Event Inquiries"
              parent="cricket_lane_booking.menu_cricket_booking_root"
              action="action_cricket_event_inquiries"
              sequence="30"/>

    <record id="crm_lead_form_cricket_event" model="ir.ui.view">
        <field name="name">crm.lead.form.cricket.event</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Cricket Event">
                    <group>
                        <field name="cricket_location_id"/>
                        <field name="cricket_booking_type_id"/>
                        <field name="cricket_event_type"/>
                        <field name="cricket_preferred_date"/>
                        <field name="cricket_preferred_time" widget="float_time"/>
                        <field name="cricket_people_count"/>
                        <field name="cricket_addon_ids" widget="many2many_tags"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
