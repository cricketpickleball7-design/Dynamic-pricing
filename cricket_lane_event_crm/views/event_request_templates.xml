<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="event_request_received_template" model="mail.template">
        <field name="name">Cricket Event Request Received</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="subject">Event request received: {{ object.name }}</field>
        <field name="email_to">{{ object.email_from }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Hello <t t-out="object.contact_name"/>,</p>
                <p>Your cricket event request has been received. Our team will contact you with a quote.</p>
            </div>
        </field>
    </record>
</odoo>
