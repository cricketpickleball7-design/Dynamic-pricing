<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_dynamic_pricing" model="ir.ui.view">
        <field name="name">product.template.form.dynamic.pricing</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_standard_price']" position="after">
                <group name="dynamic_pricing" string="Dynamic Pricing" invisible="not sale_ok">
                    <field name="dynamic_pricing_enabled"/>
                    <field name="dynamic_pricing_tz" invisible="not dynamic_pricing_enabled"/>
                    <label for="dynamic_pricing_day_price" invisible="not dynamic_pricing_enabled"/>
                    <div class="o_row" invisible="not dynamic_pricing_enabled">
                        <field
                            name="dynamic_pricing_day_price"
                            widget="monetary"
                            options="{'currency_field': 'currency_id', 'field_digits': True}"
                        />
                        <span>from</span>
                        <field name="dynamic_pricing_day_start" widget="float_time"/>
                    </div>
                    <label for="dynamic_pricing_night_price" invisible="not dynamic_pricing_enabled"/>
                    <div class="o_row" invisible="not dynamic_pricing_enabled">
                        <field
                            name="dynamic_pricing_night_price"
                            widget="monetary"
                            options="{'currency_field': 'currency_id', 'field_digits': True}"
                        />
                        <span>from</span>
                        <field name="dynamic_pricing_night_start" widget="float_time"/>
                    </div>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

