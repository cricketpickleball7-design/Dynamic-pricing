<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="appointment_dynamic_pricing_config_view_list" model="ir.ui.view">
        <field name="name">appointment.dynamic.pricing.config.list</field>
        <field name="model">appointment.dynamic.pricing.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
                <field name="appointment_type_id"/>
                <field name="product_id"/>
                <field name="base_price"/>
                <field name="minimum_price"/>
                <field name="maximum_price"/>
                <field name="maximum_adjustment_percent"/>
            </list>
        </field>
    </record>

    <record id="appointment_dynamic_pricing_config_view_form" model="ir.ui.view">
        <field name="name">appointment.dynamic.pricing.config.form</field>
        <field name="model">appointment.dynamic.pricing.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="appointment_type_id"/>
                            <field name="product_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="pricing_tz"/>
                            <field name="currency_id"/>
                        </group>
                        <group string="Price Limits">
                            <field name="base_price"/>
                            <field name="minimum_price"/>
                            <field name="maximum_price"/>
                            <field name="maximum_adjustment_percent"/>
                        </group>
                    </group>
                    <group string="Formula Weights">
                        <field name="time_weight"/>
                        <field name="traffic_weight"/>
                        <field name="session_weight"/>
                        <field name="behavior_weight"/>
                        <field name="competitor_weight"/>
                    </group>
                    <notebook>
                        <page string="Time Rules">
                            <field name="rule_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="active"/>
                                    <field name="score"/>
                                    <field name="start_time" widget="float_time"/>
                                    <field name="end_time" widget="float_time"/>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                </list>
                            </field>
                        </page>
                        <page string="Signals">
                            <field name="signal_ids">
                                <list>
                                    <field name="observed_at"/>
                                    <field name="traffic_score"/>
                                    <field name="session_score"/>
                                    <field name="behavior_score"/>
                                </list>
                            </field>
                        </page>
                        <page string="Competitors">
                            <field name="competitor_rate_ids">
                                <list>
                                    <field name="observed_at"/>
                                    <field name="competitor_name"/>
                                    <field name="competitor_price"/>
                                    <field name="competitor_score"/>
                                </list>
                            </field>
                        </page>
                        <page string="Logs">
                            <field name="log_ids">
                                <list>
                                    <field name="create_date"/>
                                    <field name="slot_datetime"/>
                                    <field name="base_price"/>
                                    <field name="final_price"/>
                                    <field name="final_score"/>
                                    <field name="reason"/>
                                    <field name="confirmed"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="appointment_dynamic_pricing_rule_view_list" model="ir.ui.view">
        <field name="name">appointment.dynamic.pricing.rule.list</field>
        <field name="model">appointment.dynamic.pricing.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
                <field name="config_id"/>
                <field name="score"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
                <field name="date_start"/>
                <field name="date_end"/>
            </list>
        </field>
    </record>

    <record id="appointment_dynamic_pricing_rule_view_form" model="ir.ui.view">
        <field name="name">appointment.dynamic.pricing.rule.form</field>
        <field name="model">appointment.dynamic.pricing.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="sequence"/>
                            <field name="config_id"/>
                            <field name="score"/>
                        </group>
                        <group>
                            <field name="start_time" widget="float_time"/>
                            <field name="end_time" widget="float_time"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                    </group>
                    <group string="Weekdays">
                        <field name="monday"/>
                        <field name="tuesday"/>
                        <field name="wednesday"/>
                        <field name="thursday"/>
                        <field name="friday"/>
                        <field name="saturday"/>
                        <field name="sunday"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="appointment_pricing_signal_view_list" model="ir.ui.view">
        <field name="name">appointment.pricing.signal.list</field>
        <field name="model">appointment.pricing.signal</field>
        <field name="arch" type="xml">
            <list>
                <field name="observed_at"/>
                <field name="config_id"/>
                <field name="traffic_count"/>
                <field name="active_session_count"/>
                <field name="behavior_event_count"/>
                <field name="traffic_score"/>
                <field name="session_score"/>
                <field name="behavior_score"/>
            </list>
        </field>
    </record>

    <record id="appointment_pricing_signal_view_form" model="ir.ui.view">
        <field name="name">appointment.pricing.signal.form</field>
        <field name="model">appointment.pricing.signal</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="config_id"/>
                            <field name="website_id"/>
                            <field name="observed_at"/>
                        </group>
                        <group>
                            <field name="traffic_count"/>
                            <field name="active_session_count"/>
                            <field name="behavior_event_count"/>
                        </group>
                    </group>
                    <group string="Scores">
                        <field name="traffic_score"/>
                        <field name="session_score"/>
                        <field name="behavior_score"/>
                    </group>
                    <field name="note"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="appointment_competitor_rate_view_list" model="ir.ui.view">
        <field name="name">appointment.competitor.rate.list</field>
        <field name="model">appointment.competitor.rate</field>
        <field name="arch" type="xml">
            <list>
                <field name="observed_at"/>
                <field name="config_id"/>
                <field name="competitor_name"/>
                <field name="competitor_price"/>
                <field name="competitor_score"/>
            </list>
        </field>
    </record>

    <record id="appointment_competitor_rate_view_form" model="ir.ui.view">
        <field name="name">appointment.competitor.rate.form</field>
        <field name="model">appointment.competitor.rate</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="config_id"/>
                            <field name="observed_at"/>
                            <field name="competitor_name"/>
                        </group>
                        <group>
                            <field name="competitor_price"/>
                            <field name="currency_id"/>
                            <field name="competitor_score"/>
                            <field name="source_url"/>
                        </group>
                    </group>
                    <field name="note"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="appointment_dynamic_price_log_view_list" model="ir.ui.view">
        <field name="name">appointment.dynamic.price.log.list</field>
        <field name="model">appointment.dynamic.price.log</field>
        <field name="arch" type="xml">
            <list create="0" edit="0">
                <field name="create_date"/>
                <field name="config_id"/>
                <field name="slot_datetime"/>
                <field name="base_price"/>
                <field name="final_price"/>
                <field name="final_score"/>
                <field name="adjustment_percent"/>
                <field name="reason"/>
                <field name="confirmed"/>
            </list>
        </field>
    </record>

    <record id="appointment_dynamic_price_log_view_form" model="ir.ui.view">
        <field name="name">appointment.dynamic.price.log.form</field>
        <field name="model">appointment.dynamic.price.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="config_id"/>
                            <field name="appointment_type_id"/>
                            <field name="product_id"/>
                            <field name="slot_datetime"/>
                            <field name="currency_id"/>
                            <field name="confirmed"/>
                        </group>
                        <group>
                            <field name="base_price"/>
                            <field name="minimum_price"/>
                            <field name="maximum_price"/>
                            <field name="raw_price"/>
                            <field name="final_price"/>
                            <field name="adjustment_percent"/>
                        </group>
                    </group>
                    <group string="Scores">
                        <field name="final_score"/>
                        <field name="time_score"/>
                        <field name="traffic_score"/>
                        <field name="session_score"/>
                        <field name="behavior_score"/>
                        <field name="competitor_score"/>
                    </group>
                    <group string="References">
                        <field name="applied_rule_id"/>
                        <field name="signal_id"/>
                        <field name="competitor_rate_id"/>
                        <field name="sale_order_line_id"/>
                        <field name="calendar_event_id"/>
                    </group>
                    <field name="reason"/>
                    <field name="request_payload"/>
                    <field name="response_payload"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="appointment_dynamic_pricing_config_action" model="ir.actions.act_window">
        <field name="name">Pricing Configurations</field>
        <field name="res_model">appointment.dynamic.pricing.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="appointment_dynamic_pricing_rule_action" model="ir.actions.act_window">
        <field name="name">Time Rules</field>
        <field name="res_model">appointment.dynamic.pricing.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="appointment_pricing_signal_action" model="ir.actions.act_window">
        <field name="name">Pricing Signals</field>
        <field name="res_model">appointment.pricing.signal</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="appointment_competitor_rate_action" model="ir.actions.act_window">
        <field name="name">Competitor Rates</field>
        <field name="res_model">appointment.competitor.rate</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="appointment_dynamic_price_log_action" model="ir.actions.act_window">
        <field name="name">Price Logs</field>
        <field name="res_model">appointment.dynamic.price.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

