<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cricket_booking_list" model="ir.ui.view">
        <field name="name">cricket.booking.list</field>
        <field name="model">cricket.booking</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="state"/>
                <field name="partner_id"/>
                <field name="location_id"/>
                <field name="booking_type_id"/>
                <field name="lane_ids" widget="many2many_tags"/>
                <field name="slot_start"/>
                <field name="play_end"/>
                <field name="slot_count"/>
                <field name="people_count"/>
                <field name="price_total"/>
                <field name="sale_order_id"/>
            </list>
        </field>
    </record>

    <record id="view_cricket_booking_form" model="ir.ui.view">
        <field name="name">cricket.booking.form</field>
        <field name="model">cricket.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_checked_in" type="object" string="Check In" class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_completed" type="object" string="Complete" class="btn-primary" invisible="state != 'checked_in'"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="state in ['cancelled', 'completed']"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="customer_first_name"/>
                            <field name="customer_last_name"/>
                            <field name="customer_phone"/>
                            <field name="customer_email"/>
                        </group>
                        <group>
                            <field name="location_id"/>
                            <field name="booking_type_id"/>
                            <field name="lane_ids" widget="many2many_tags"/>
                            <field name="people_count"/>
                            <field name="addon_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group string="Slot">
                        <field name="slot_start"/>
                        <field name="play_end"/>
                        <field name="slot_end"/>
                        <field name="slot_count"/>
                    </group>
                    <group string="Commerce">
                        <field name="price_total"/>
                        <field name="currency_id"/>
                        <field name="hold_id"/>
                        <field name="sale_order_id"/>
                        <field name="payment_transaction_id"/>
                        <field name="invoice_id"/>
                    </group>
                    <group string="Calendar">
                        <field name="calendar_event_id"/>
                        <field name="appointment_type_id"/>
                    </group>
                    <field name="cancellation_policy_text"/>
                    <field name="price_breakdown_json"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_cricket_booking_calendar" model="ir.ui.view">
        <field name="name">cricket.booking.calendar</field>
        <field name="model">cricket.booking</field>
        <field name="arch" type="xml">
            <calendar string="Cricket Bookings" date_start="slot_start" date_stop="slot_end" color="booking_type_id">
                <field name="name"/>
                <field name="lane_ids"/>
                <field name="people_count"/>
            </calendar>
        </field>
    </record>
</odoo>
