<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cricket_location_list" model="ir.ui.view">
        <field name="name">cricket.location.list</field>
        <field name="model">cricket.location</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="timezone"/>
                <field name="default_open_time" widget="float_time"/>
                <field name="default_close_time" widget="float_time"/>
                <field name="minimum_notice_minutes"/>
                <field name="max_booking_days_ahead"/>
                <field name="website_published"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_cricket_location_form" model="ir.ui.view">
        <field name="name">cricket.location.form</field>
        <field name="model">cricket.location</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="timezone"/>
                            <field name="currency_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="website_published"/>
                            <field name="active"/>
                            <field name="hold_minutes"/>
                        </group>
                    </group>
                    <group string="Default Booking Window">
                        <field name="default_open_time" widget="float_time"/>
                        <field name="default_close_time" widget="float_time"/>
                        <field name="minimum_notice_minutes"/>
                        <field name="max_booking_days_ahead"/>
                    </group>
                    <notebook>
                        <page string="Lanes">
                            <field name="lane_ids"/>
                        </page>
                        <page string="Slot Rules">
                            <field name="slot_rule_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>
