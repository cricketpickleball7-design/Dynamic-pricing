<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cricket_lane_list" model="ir.ui.view">
        <field name="name">cricket.lane.list</field>
        <field name="model">cricket.lane</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="location_id"/>
                <field name="length_ft"/>
                <field name="lane_type"/>
                <field name="base_price"/>
                <field name="max_people"/>
                <field name="website_status"/>
                <field name="website_published"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_cricket_lane_kanban" model="ir.ui.view">
        <field name="name">cricket.lane.kanban</field>
        <field name="model">cricket.lane</field>
        <field name="arch" type="xml">
            <kanban default_group_by="location_id">
                <field name="name"/>
                <field name="location_id"/>
                <field name="length_ft"/>
                <field name="lane_type"/>
                <field name="base_price"/>
                <field name="currency_id"/>
                <field name="website_status"/>
                <field name="today_booking_count"/>
                <field name="active_hold_count"/>
                <field name="active_block_count"/>
                <field name="next_booking_start"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <strong><field name="name"/></strong>
                                <field name="website_status"/>
                            </div>
                            <div class="text-muted mb-2">
                                <field name="length_ft"/> FT - <field name="lane_type"/>
                            </div>
                            <div class="d-flex gap-2 flex-wrap mb-2">
                                <span class="badge text-bg-primary">Today: <field name="today_booking_count"/></span>
                                <span class="badge text-bg-warning">Holds: <field name="active_hold_count"/></span>
                                <span class="badge text-bg-secondary">Blocks: <field name="active_block_count"/></span>
                            </div>
                            <div>
                                <span>Base </span><field name="base_price"/>
                            </div>
                            <div t-if="record.next_booking_start.raw_value" class="text-muted">
                                Next: <field name="next_booking_start"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_cricket_lane_form" model="ir.ui.view">
        <field name="name">cricket.lane.form</field>
        <field name="model">cricket.lane</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="location_id"/>
                            <field name="sequence"/>
                            <field name="length_ft"/>
                            <field name="lane_type"/>
                        </group>
                        <group>
                            <field name="base_price"/>
                            <field name="included_people"/>
                            <field name="extra_person_fee"/>
                            <field name="max_people"/>
                            <field name="website_status"/>
                            <field name="website_published"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Bundle" invisible="lane_type != 'box_bundle'">
                        <field name="lane_ids" widget="many2many_tags"/>
                    </group>
                    <group string="Dashboard">
                        <field name="today_booking_count"/>
                        <field name="active_hold_count"/>
                        <field name="active_block_count"/>
                        <field name="next_booking_start"/>
                    </group>
                    <group string="Odoo Integration">
                        <field name="appointment_type_id"/>
                        <field name="appointment_resource_id"/>
                        <field name="calendar_resource_id"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>
